{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "viam:beanjamin",
  "visibility": "public",
  "url": "https://github.com/viamrobotics/beanjamin",
  "description": "Beanjamin module: coffee service and multi-poses execution switch",
  "models": [
    {
      "api": "rdk:service:generic",
      "model": "viam:beanjamin:coffee",
      "short_description": "Orchestrates a full coffee brew cycle by sequentially moving through poses on a pose switcher.",
      "markdown_link": "README.md#model-viambeanjamincoffee"
    },
    {
      "api": "rdk:component:switch",
      "model": "viam:beanjamin:multi-poses-execution-switch",
      "short_description": "Switch that moves an arm between predefined poses via the Motion service.",
      "markdown_link": "README.md#model-viambeanjaminmulti-poses-execution-switch"
    },
    {
      "api": "rdk:component:sensor",
      "model": "viam:beanjamin:maintenance-sensor",
      "short_description": "Sensor that reports safe=false when the arm is moving or orders are queued.",
      "markdown_link": "README.md#model-viambeanjaminmaintenance-sensor"
    },
    {
      "api": "rdk:component:sensor",
      "model": "viam:beanjamin:order-sensor",
      "short_description": "Sensor that queues one reading per order with start/end times and outcome.",
      "markdown_link": "README.md#model-viambeanjaminorder-sensor"
    },
    {
      "api": "rdk:service:generic",
      "model": "viam:beanjamin:dial-control-motion",
      "short_description": "Translates dial inputs into relative arm motions along the X/Y/Z axes or orientation vector.",
      "markdown_link": "README.md#model-viambeanjamindial-control-motion"
    },
    {
      "api": "rdk:service:generic",
      "model": "viam:beanjamin:customer-detector",
      "short_description": "Identifies return customers via facial recognition using the face-identification vision service.",
      "markdown_link": "README.md#model-viambeanjamincustomer-detector"
    },
    {
      "api": "rdk:service:generic",
      "model": "viam:beanjamin:delivery-handler",
      "short_description": "Receiving end of the coffee delivery messaging channel; accepts one-way messages over a remote part.",
      "markdown_link": "README.md#model-viambeanjamindelivery-handler"
    }
  ],
  "entrypoint": "bin/beanjamin",
  "first_run": "first_run.sh",
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64",
      "windows/amd64"
    ]
  }
}